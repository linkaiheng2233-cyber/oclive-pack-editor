{
  "name": "oclive-pack-editor",
  "private": true,
  "version": "0.5.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:browser": "vite --open",
    "build": "vue-tsc -b && vite build",
    "check": "npm run build && npm run test && npm run contract:json-keys",
    "preview": "vite preview",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "cargo:build": "cargo build --manifest-path src-tauri/Cargo.toml",
    "wasm:build": "node scripts/wasm-pack-build.mjs",
    "contract:json-keys": "node scripts/diff-json-keys.mjs"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.1",
    "jszip": "^3.10.1",
    "vue": "^3.5.32",
    "vue-i18n": "^11.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.0",
    "@tauri-apps/cli": "1.5.14",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.1",
    "happy-dom": "^20.8.9",
    "typescript": "~6.0.2",
    "vite": "^8.0.4",
    "vitest": "^4.1.2",
    "vue-tsc": "^3.2.6"
  }
}
